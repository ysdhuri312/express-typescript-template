{
  "name": "express-typscript-template",
  "module": "index.ts",
  "main": "server.ts",
  "scripts": {
    "build": "tsc",
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "cross-env NODE_ENV=production node ./dist/server.js",
    "dev": "cross-env NODE_ENV=development nodemon --watch src --ext ts --exec tsx src/server.ts",
    "lint:check": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "latest",
    "@types/express": "^5.0.6",
    "cross-env": "^10.1.0",
    "eslint": "^10.7.0",
    "nodemon": "^3.1.14",
    "tsx": "^4.23.1",
    "typescript-eslint": "^8.63.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "private": true,
  "type": "module",
  "dependencies": {
    "dotenv": "^17.4.2",
    "express": "^5.2.1"
  }
}
